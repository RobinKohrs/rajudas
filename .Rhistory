# data -------------------------------------------------------------------
d = neusiedlData$nied %>%
mutate(
data = case_when(
data == -1 ~ NA,
.default = data
),
year = lubridate::year(time),
month = lubridate::month(time)
) %>%
group_by(year, month) %>%
summarise(
sumPerMonth = sum(data, na.rm = T)
)
d
ggplto(d, aes(month, sumPerMonth, color=year)) +
geom_line()
ggplot(d, aes(month, sumPerMonth, color=year)) +
geom_line()
ggplot(d, aes(month, sumPerMonth, color=year, group=year)) +
geom_line()
