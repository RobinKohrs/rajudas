library(sf)
library(here)
library(rajudas)
library(stars)
library(mapview)
library(tidyverse)
# stationen ---------------------------------------------------------------
stations = zamg_downloadStations()
stations = stations %>%
mutate(
x = st_coordinates(.)[,1],
y = st_coordinates(.)[,2]
) %>% st_drop_geometry() %>%
st_as_sf(coords=c("y", "x"), crs=4326)
# neusiedl am see ---------------------------------------------------------
neusiedl = stations %>% filter(id==65)
start = neusiedl$valid_from %>% as.Date()
id = 65
