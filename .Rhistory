# data -------------------------------------------------------------------
d = neusiedlData$nied %>%
mutate(
data = case_when(
data == -1 ~ NA,
.default = data
),
year = lubridate::year(time),
month = lubridate::month(time)
) %>%
group_by(year, month) %>%
summarise(
sumPerMonth = sum(data, na.rm = T)
) %>%
mutate(
fakeDate = as.Date(glue("2000-{month}-01"))
) %>%
mutate(
color = ifelse(year %in% 2020:2023, "darkred", "grey")
)
ggplot(d, aes(fakeDate, sumPerMonth, color=color, group=year)) +
scale_color_identity() +
scale_x_date(date_labels = "%m") +
theme_light() +
geom_line()
ggplot(d, aes(fakeDate, sumPerMonth, color=color, group=year)) +
scale_color_identity() +
scale_x_date(date_labels = "%m") +
theme_light() +
labs(
x = "Monat",
y = "Summe an Niederschlag pro Monat",
title ="Station Neusiedl am See [id=65]"
)
ggplot(d, aes(fakeDate, sumPerMonth, color=color, group=year)) +
scale_color_identity() +
scale_x_date(date_labels = "%m") +
theme_light() +
labs(
